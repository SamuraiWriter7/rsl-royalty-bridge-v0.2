{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kazene.dev/schema/rsl-royalty-bridge-v0.2.schema.json",
  "title": "RSL-to-Kazene Royalty Bridge Specification v0.2",
  "description": "JSON Schema for the RSL-to-Kazene Royalty Bridge Specification v0.2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bridge_version",
    "bridge_record_id",
    "created_at",
    "updated_at",
    "status",
    "sync_ids",
    "idempotency",
    "compatibility",
    "access_snapshot",
    "external_charge_event",
    "royalty_settlement",
    "verification"
  ],
  "properties": {
    "bridge_version": {
      "type": "string",
      "const": "0.2"
    },
    "bridge_record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "blocked_or_pending",
        "ready",
        "rejected",
        "settled",
        "reversed"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sync_ids": {
      "$ref": "#/$defs/sync_ids"
    },
    "idempotency": {
      "$ref": "#/$defs/idempotency"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "access_snapshot": {
      "$ref": "#/$defs/access_snapshot"
    },
    "external_charge_event": {
      "$ref": "#/$defs/external_charge_event"
    },
    "royalty_settlement": {
      "$ref": "#/$defs/royalty_settlement"
    },
    "verification": {
      "$ref": "#/$defs/verification"
    },
    "extensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/extension_entry"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableNonEmptyString": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "currencyCode": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "sync_ids": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id",
        "rsl_report_id",
        "trace_event_id",
        "inference_event_id",
        "external_charge_event_id",
        "royalty_settlement_id"
      ],
      "properties": {
        "correlation_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "rsl_report_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "trace_event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "inference_event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "external_charge_event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "royalty_settlement_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "recomputation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_recalculation",
        "prior_settlement_id",
        "recompute_reason",
        "recompute_version"
      ],
      "properties": {
        "is_recalculation": {
          "type": "boolean"
        },
        "prior_settlement_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "recompute_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "recompute_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotency_key",
        "dedupe_scope",
        "dedupe_hash",
        "replay_sequence"
      ],
      "properties": {
        "idempotency_key": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dedupe_scope": {
          "type": "string",
          "enum": [
            "inference_event",
            "external_charge_event",
            "royalty_settlement"
          ]
        },
        "dedupe_hash": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "replay_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "prior_event_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "recomputation": {
          "$ref": "#/$defs/recomputation"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec_family",
        "compatibility_level",
        "extension_namespace"
      ],
      "properties": {
        "spec_family": {
          "type": "string",
          "const": "rsl-kazene-bridge"
        },
        "compatibility_level": {
          "type": "string",
          "enum": [
            "strict",
            "compatible",
            "informational",
            "experimental"
          ]
        },
        "extension_namespace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "access_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "access_time",
        "requester_type",
        "requester_id",
        "asset_ref",
        "usage_context"
      ],
      "properties": {
        "access_time": {
          "type": "string",
          "format": "date-time"
        },
        "requester_type": {
          "type": "string",
          "enum": [
            "human_user",
            "ai_agent",
            "service_account",
            "batch_job",
            "unknown"
          ]
        },
        "requester_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "asset_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "usage_context": {
          "type": "string",
          "enum": [
            "licensed_inference",
            "retrieval",
            "summarization",
            "embedding",
            "evaluation",
            "other"
          ]
        },
        "source_system": {
          "type": "string"
        },
        "license_context": {
          "type": "string"
        },
        "usage_units": {
          "type": "number",
          "minimum": 0
        },
        "usage_unit_type": {
          "type": "string"
        }
      }
    },
    "external_charge_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "charge_time",
        "currency",
        "gross_amount",
        "billing_basis"
      ],
      "properties": {
        "charge_time": {
          "type": "string",
          "format": "date-time"
        },
        "currency": {
          "$ref": "#/$defs/currencyCode"
        },
        "gross_amount": {
          "type": "number",
          "minimum": 0
        },
        "net_amount": {
          "type": "number",
          "minimum": 0
        },
        "tax_amount": {
          "type": "number",
          "minimum": 0
        },
        "billing_basis": {
          "type": "string",
          "enum": [
            "per_inference",
            "per_token",
            "per_request",
            "per_batch",
            "subscription_allocation",
            "hybrid",
            "other"
          ]
        },
        "charge_status": {
          "type": "string",
          "enum": [
            "observed",
            "authorized",
            "captured",
            "failed",
            "reversed"
          ]
        },
        "payer_ref": {
          "type": "string"
        },
        "invoice_ref": {
          "type": "string"
        }
      }
    },
    "royalty_settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "settlement_status",
        "settlement_amount",
        "settlement_currency"
      ],
      "properties": {
        "settlement_status": {
          "type": "string",
          "enum": [
            "not_ready",
            "eligible",
            "calculated",
            "settled",
            "rejected",
            "reversed"
          ]
        },
        "settlement_amount": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "settlement_currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3}$"
        },
        "settlement_time": {
          "type": "string",
          "format": "date-time"
        },
        "allocation_basis": {
          "type": "string"
        },
        "beneficiary_ref": {
          "type": "string"
        },
        "settlement_memo": {
          "type": "string"
        }
      }
    },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signer_type",
        "signer_id",
        "key_id"
      ],
      "properties": {
        "signer_type": {
          "type": "string",
          "enum": [
            "platform",
            "publisher",
            "license_server",
            "ai_provider",
            "auditor",
            "other"
          ]
        },
        "signer_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "key_id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "signature_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "signed_fields",
        "signer",
        "signature",
        "signed_at"
      ],
      "properties": {
        "algorithm": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "signed_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "access_snapshot",
              "external_charge_event",
              "royalty_settlement"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "access_snapshot"
              }
            },
            {
              "contains": {
                "const": "external_charge_event"
              }
            },
            {
              "contains": {
                "const": "royalty_settlement"
              }
            }
          ]
        },
        "signer": {
          "$ref": "#/$defs/signer"
        },
        "signature": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "verification_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "checked_at",
        "verifier_id",
        "failure_reason"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "failed",
            "not_checked"
          ]
        },
        "checked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "verifier_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "failure_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature_bundle",
        "verification_result"
      ],
      "properties": {
        "signature_bundle": {
          "$ref": "#/$defs/signature_bundle"
        },
        "verification_result": {
          "$ref": "#/$defs/verification_result"
        }
      }
    },
    "extension_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "extension_namespace",
        "extension_key",
        "value",
        "compatibility_level"
      ],
      "properties": {
        "extension_namespace": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "extension_key": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "value": {},
        "compatibility_level": {
          "type": "string",
          "enum": [
            "strict",
            "compatible",
            "informational",
            "experimental"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ready"
          }
        }
      },
      "then": {
        "properties": {
          "sync_ids": {
            "properties": {
              "rsl_report_id": {
                "type": "string",
                "minLength": 1
              },
              "trace_event_id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "idempotency": {
            "properties": {
              "idempotency_key": {
                "type": "string",
                "minLength": 1
              },
              "dedupe_hash": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "verification": {
            "properties": {
              "verification_result": {
                "properties": {
                  "status": {
                    "enum": [
                      "verified",
                      "not_checked"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "settled"
          }
        }
      },
      "then": {
        "properties": {
          "sync_ids": {
            "properties": {
              "rsl_report_id": {
                "type": "string",
                "minLength": 1
              },
              "trace_event_id": {
                "type": "string",
                "minLength": 1
              },
              "royalty_settlement_id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "royalty_settlement": {
            "properties": {
              "settlement_status": {
                "const": "settled"
              },
              "settlement_amount": {
                "type": "number",
                "minimum": 0
              },
              "settlement_currency": {
                "$ref": "#/$defs/currencyCode"
              }
            }
          },
          "verification": {
            "properties": {
              "verification_result": {
                "properties": {
                  "status": {
                    "const": "verified"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "reversed"
          }
        }
      },
      "then": {
        "properties": {
          "royalty_settlement": {
            "properties": {
              "settlement_status": {
                "const": "reversed"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification": {
            "properties": {
              "verification_result": {
                "properties": {
                  "status": {
                    "const": "failed"
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "status": {
            "enum": [
              "blocked_or_pending",
              "rejected"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "sync_ids": {
            "properties": {
              "rsl_report_id": {
                "type": "null"
              },
              "trace_event_id": {
                "type": "null"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "status": {
            "const": "rejected"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compatibility": {
            "properties": {
              "compatibility_level": {
                "enum": [
                  "informational",
                  "experimental"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "status": {
            "enum": [
              "pending",
              "blocked_or_pending",
              "rejected"
            ]
          }
        }
      }
    }
  ]
}
